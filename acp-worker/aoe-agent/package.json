{
  "name": "aoe-agent",
  "version": "0.0.1",
  "description": "Multi-provider ACP agent for the Agent of Empires structured view. Wraps Vercel AI SDK 6 in an ACP server.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "aoe-agent": "src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --experimental-strip-types --test test/*.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.25.0",
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "ai": "^6.0.205",
    "zod": "^4.4.3"
  },
  "license": "MIT"
}
