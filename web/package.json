{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "coverage:merge": "node scripts/merge-coverage.mjs",
    "coverage:all": "rm -rf coverage && AOE_COVERAGE=1 npm run test:unit -- --coverage && AOE_COVERAGE=1 npx playwright test && npm run coverage:merge"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.21",
    "@assistant-ui/react-markdown": "^0.14.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@pierre/diffs": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.11",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.7",
    "react-joyride": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "diff": "^8.0.4",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "monocart-coverage-reports": "^2.12.12",
    "msw": "^2.14.6",
    "oxfmt": "^0.53.0",
    "tslib": "^2.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "@codecov/vite-plugin": {
      "vite": "$vite"
    }
  }
}
